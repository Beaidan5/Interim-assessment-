# Frontend environment variables
# Copy this file to .env and fill in the values

# URL of the deployed backend (no trailing slash)
# Development: leave blank to use the default http://localhost:5001/api
# Production:  set to your Render backend URL, e.g. https://your-app.onrender.com/api
VITE_API_URL=http://localhost:5001/api

# Backend environment variables (for Render deployment)
# MongoDB connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/crypto-app?retryWrites=true&w=majority

# JWT secret for authentication tokens (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Frontend URL for CORS (where your Netlify app is deployed)
FRONTEND_URL=https://your-app.netlify.app

# Port for backend server (Render will set this automatically)
PORT=5001
